FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ARG VITE_BACKEND_URL=http://localhost:3001
ARG VITE_BASE_PATH=/chatbot/
ARG VITE_ANALYTICS_URL=
ARG VITE_ANALYTICS_TOKEN
ARG VITE_SPARQL_ENDPOINT=changeme
ENV VITE_BACKEND_URL=$VITE_BACKEND_URL
ENV VITE_BASE_PATH=$VITE_BASE_PATH
ENV VITE_ANALYTICS_URL=$VITE_ANALYTICS_URL
ENV VITE_ANALYTICS_TOKEN=$VITE_ANALYTICS_TOKEN
ENV VITE_SPARQL_ENDPOINT=$VITE_SPARQL_ENDPOINT
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html/chatbot
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
