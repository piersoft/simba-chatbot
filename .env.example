# ── Rete ─────────────────────────────────────────────────────────────────────
SERVER_IP=192.168.0.126
MCP_PORT=3000
BACKEND_PORT=3001
FRONTEND_PORT=8080

# ── Provider LLM ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama

# ── Ollama (locale o cloud) ───────────────────────────────────────────────────
# Locale:   OLLAMA_URL=http://ollama:11434
# Cloud:    OLLAMA_URL=https://ollama.com
OLLAMA_URL=http://ollama:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen2.5:0.5b
# Modello separato per il classificatore di intent (opzionale, uso avanzato).
# Utile se OLLAMA_MODEL è un modello grande (1.7b+) usato per chat libere e
# vuoi un classifier più veloce. Nella config attuale di SIMBA (solo classifier,
# no chat) OLLAMA_MODEL è già piccolo e questa variabile resta VUOTA.
# Se valorizzata, scarica prima il modello: docker compose exec ollama ollama pull MODEL
OLLAMA_INTENT_MODEL=
# Numero di richieste LLM concorrenti gestite da Ollama (default 1).
# Alzare a 2-4 se si usa modello piccolo (0.5b) su CPU multi-core dedicati.
# Ogni slot aggiuntivo = +500MB RAM + 1 core CPU saturato per inferenza.
OLLAMA_NUM_PARALLEL=

# ── Produzione con nginx reverse proxy ───────────────────────────────────────
# Se usi nginx come reverse proxy sullo stesso server (consigliato):
#   VITE_BACKEND_URL=           ← lascia vuoto, le chiamate /api/ passano per nginx
#   CORS_ORIGIN=http://31.14.xxx.x  ← il tuo IP o dominio pubblico
#
# Se accedi direttamente senza nginx (sviluppo):
#   VITE_BACKEND_URL=http://31.14.xxx.x:3001
#   CORS_ORIGIN=http://31.14.xxx.x:8080
VITE_BACKEND_URL=
CORS_ORIGIN=

# ── Analytics ─────────────────────────────────────────────────────────────────
ANALYTICS_PORT=3004
# Token per proteggere gli endpoint /stats/* (cambia in produzione!)
ANALYTICS_TOKEN=changeme
ADMIN_TOKEN=changeme-admin
VITE_ADMIN_TOKEN=changeme-admin
# Origin del chatbot per il CORS dell'analytics-service
# OBBLIGATORIO: origin consentito per il CORS di analytics-service.
# Senza questa variabile analytics-service non parte (exit 1).
# Esempio: https://chatbot.tuo-ente.it
CHATBOT_ORIGIN=https://chatbot.piersoftckan.biz
# URL analytics visto dal frontend (lascia vuoto se usi nginx proxy)
VITE_ANALYTICS_URL=
VITE_ANALYTICS_TOKEN=changeme
VITE_ADMIN_TOKEN=changeme-admin

# ── Endpoint SPARQL ───────────────────────────────────────────────────────────
# Endpoint SPARQL per la ricerca dataset.
# Default: lod.dati.gov.it (catalogo nazionale italiano)
# Cambiare se si usa un triplestore diverso (es. endpoint locale, altro catalogo)
# SPARQL_ENDPOINT=https://lod.dati.gov.it/sparql
SPARQL_ENDPOINT=

# ── Load testing ──────────────────────────────────────────────────────────────
# Controlla bypass dei rate limiter per load testing:
#   vuoto     = nessun bypass (default, obbligatorio in produzione)
#   "*"       = bypass TOTALE di tutti i rate limiter (pericoloso, solo test isolati)
#   "172.x.y" = bypass solo per quell'IP specifico (safer ma richiede di sapere l'IP)
# Al boot il backend logga la modalità attiva. RIMUOVERE DOPO IL TEST.
LOADTEST_BYPASS_IP=
