{
  "name": "@aborruso/ckan-mcp-server",
  "version": "0.4.76",
  "description": "MCP server for interacting with CKAN open data portals",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "ckan-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:axios --external:express --external:zod",
    "build:tsc": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc",
    "build:worker": "esbuild src/worker.ts --bundle --platform=browser --format=esm --outfile=dist/worker.js --target=es2022 --minify",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "dev:worker": "wrangler dev",
    "watch": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:axios --external:express --external:zod --watch",
    "deploy": "npm run build:worker && wrangler deploy",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "build:dxt": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dxt-staging/server/index.js",
    "pack:dxt": "rm -rf dxt-staging && mkdir -p dxt-staging/server && npm run build:dxt && echo '{\"type\":\"commonjs\"}' > dxt-staging/server/package.json && cp manifest.json icon.png dxt-staging/ && dxt pack dxt-staging ckan-mcp-server.dxt && rm -rf dxt-staging",
    "prepack": "cp README.md .readme-full.md && cp .readme-npm.md README.md",
    "postpack": "mv .readme-full.md README.md"
  },
  "keywords": [
    "mcp",
    "ckan",
    "open-data",
    "api",
    "data-portal"
  ],
  "author": "Andrea Borruso <aborruso@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "axios": "^1.7.2",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.16",
    "esbuild": "^0.27.2",
    "typescript": "^5.4.5",
    "vitest": "^4.0.16",
    "wrangler": "^4.58.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE.txt",
    "NOTICE.md",
    "LOG.md",
    "EXAMPLES.md",
    "AGENTS.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
